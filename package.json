{
  "name": "dev-auth-fetcher",
  "version": "0.1.0",
  "private": true,
  "description": "CLI pour connecter un environnement local aux environnements de recette et injecter les cookies d'authentification dans les fichiers .env des frontends.",
  "bin": {
    "dev-auth-fetcher": "bin/dev-auth-fetcher"
  },
  "scripts": {
    "dev": "ts-node src/cli/index.ts",
    "build": "tsup src/cli/index.ts --out-dir dist --format cjs --dts --sourcemap --no-splitting",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.3.0",
    "ora": "^8.0.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.10.0",
    "@types/inquirer": "^9.0.7",
    "@types/ora": "^3.2.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
